# Auto detect text files and perform LF normalization
* text=auto

# Source files
*.js text eol=lf
*.ts text eol=lf
*.jsx text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.sh text eol=lf

# Binary files
*.png binary
*.jpg binary
*.ico binary
*.svg binary
*.woff binary
*.woff2 binary

# Git files
.gitattributes text eol=lf
.gitignore text eol=lf
