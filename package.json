{
  "name": "freellmapi",
  "private": true,
  "workspaces": [
    "shared",
    "server",
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w server\" \"npm run dev -w client\"",
    "test": "npm run test -w server && npm run test -w client --if-present",
    "build": "npm run build -w server && npm run build -w client",
    "build:server": "npm run build -w server",
    "start": "node server/dist/index.js"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  },
  "author": "Rahaman Leon (rahamanleon16@gmail.com)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rahamanleon/freellmapi.git"
  },
  "bugs": {
    "url": "https://github.com/rahamanleon/freellmapi/issues"
  },
  "homepage": "https://github.com/rahamanleon/freellmapi",
  "license": "MIT"
}
